# Development database used by the app / manual runs.
CDITOR_DATABASE_URL=postgres://cditor:cditor@localhost:5432/cditor_dev

# Isolated database used by integration tests.
CDITOR_TEST_DATABASE_URL=postgres://cditor:cditor@localhost:5433/cditor_test

# Inline AI token. Non-secret provider settings live in config/ai.toml.
# Copy this file to .env and set a real key locally. Do not commit .env.
CDITOR_AI_API_KEY=
